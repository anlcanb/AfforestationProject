@model Afforestation.WebUI.Models.ViewModels.ObservationViewModel

@{
    ViewData["Title"] = "Gözlem Ekle";
}

<h2>Gözlem Ekle</h2>

<form asp-action="AddObservation" method="post">
    <input type="hidden" asp-for="SiteId" />

    <div class="mb-3">
        <label asp-for="Date" class="form-label">Tarih</label>
        <input asp-for="Date" class="form-control" type="date" />
    </div>

    <div class="mb-3">
        <label asp-for="ProductivityScore" class="form-label">Verimlilik Skoru</label>
        <input asp-for="ProductivityScore" class="form-control" type="number" min="0" max="100" />
    </div>

    <div class="mb-3">
        <label asp-for="Note" class="form-label">Not</label>
        <textarea asp-for="Note" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Details" asp-route-id="@Model.SiteId" class="btn btn-secondary">İptal</a>
</form>