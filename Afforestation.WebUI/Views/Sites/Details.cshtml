@model Afforestation.WebUI.Models.ViewModels.SiteDetailViewModel

@{
    ViewData["Title"] = "Saha Detayları";
}

<h2>@Model.Name</h2>
<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Şehir</dt>
            <dd class="col-sm-8">@Model.City</dd>

            <dt class="col-sm-4">İlçe</dt>
            <dd class="col-sm-8">@Model.District</dd>

            <dt class="col-sm-4">Enlem</dt>
            <dd class="col-sm-8">@Model.Latitude</dd>

            <dt class="col-sm-4">Boylam</dt>
            <dd class="col-sm-8">@Model.Longitude</dd>

            <dt class="col-sm-4">Durum</dt>
            <dd class="col-sm-8">@Model.Status</dd>
        </dl>

        <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.Id">Düzenle</a>
        <a class="btn btn-primary" asp-action="Index">Listeye Dön</a>
        <a class="btn btn-success" asp-action="AddObservation" asp-route-siteId="@Model.Id">Gözlem Ekle</a>
    </div>

    <div class="col-md-6">
        <h4>Gözlemler</h4>
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>Verimlilik</th>
                    <th>Not</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Observations)
                {
                    <tr>
                        <td>@o.Date.ToString("yyyy-MM-dd")</td>
                        <td>@o.ProductivityScore</td>
                        <td>@o.Note</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>