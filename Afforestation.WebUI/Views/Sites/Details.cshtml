@model Afforestation.WebUI.Models.ViewModels.SiteDetailViewModel

@{
    ViewData["Title"] = "Site Details";
}

<h2>@Model.Name</h2>
<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">City</dt>
            <dd class="col-sm-8">@Model.City</dd>

            <dt class="col-sm-4">District</dt>
            <dd class="col-sm-8">@Model.District</dd>

            <dt class="col-sm-4">Latitude</dt>
            <dd class="col-sm-8">@Model.Latitude</dd>

            <dt class="col-sm-4">Longitude</dt>
            <dd class="col-sm-8">@Model.Longitude</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>
        </dl>

        <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-primary" asp-action="Index">Back to list</a>
    </div>

    <div class="col-md-6">
        <h4>Observations</h4>
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Productivity</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Observations)
                {
                    <tr>
                        <td>@o.Date.ToString("yyyy-MM-dd")</td>
                        <td>@o.ProductivityScore</td>
                        <td>@o.Note</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
