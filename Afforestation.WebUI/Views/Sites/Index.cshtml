@model IEnumerable<Afforestation.WebUI.Models.ViewModels.SiteListItemViewModel>

@{
    ViewData["Title"] = "Sites";
}

<div class="d-flex justify-content-between mb-3">
    <h2>Sites</h2>
    <a class="btn btn-primary" asp-action="Create">Create Site</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>City</th>
            <th>District</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.City</td>
                <td>@s.District</td>
                <td>@s.Status</td>
                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@s.Id">Details</a>
                    <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@s.Id">Edit</a>
                    <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                        <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4">
    <a class="btn btn-success" asp-action="Map">View Map</a>
</div>
